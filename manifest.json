{
  "manifest_version": 3,
  "name": "智能網頁翻譯助手",
  "version": "2.0.0",
  "description": "智能網頁翻譯助手 - 選中文字即可快速翻譯，支持多種翻譯引擎",
  "author": "Screenshot Translator Team",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "notifications"
  ],
  "host_permissions": [
    "https://translate.googleapis.com/*",
    "https://api.mymemory.translated.net/*",
    "https://api.cognitive.microsofttranslator.com/*",
    "https://open.bigmodel.cn/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "智能網頁翻譯助手 - 點擊開始",
    "default_icon": {
      "16": "icons/icon16.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js", "quick-panel.js"],
      "css": ["content.css", "quick-panel.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "smart-translate": {
      "suggested_key": {
        "default": "Alt+1",
        "mac": "Alt+1",
        "windows": "Alt+1",
        "linux": "Alt+1"
      },
      "description": "智能翻譯（自動檢測語言翻譯成目標語言）"
    }
  }
}
